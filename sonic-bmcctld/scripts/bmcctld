# ============================================================
# Helper utilities
# ============================================================


def get_current_timestamp():
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")


def try_get(callback, *args, default=NOT_AVAILABLE):
    """Invoke callback; return default on NotImplementedError or None result."""
    try:
        ret = callback(*args)
        if ret is None:
            ret = default
    except NotImplementedError:
        ret = default
    return ret


def fvs_to_dict(fvs):
    """Convert swsscommon FieldValuePairs list of (field, value) tuples to dict."""
    if fvs is None:
        return {}
    if isinstance(fvs, dict):
        return fvs
    return dict(fvs)


# ============================================================
# SwitchHostController
# ============================================================

class SwitchHostController(EventLogger):
    """
    Wraps platform Module API to power ON/OFF/cycle the Switch-Host and
    tracks its state in the HOST_STATE STATE_DB table.
    """

    def __init__(self, chassis):
        super(SwitchHostController, self).__init__(SYSLOG_IDENTIFIER, CRITICAL_EVENT_LOG_FILE)
        self.chassis = chassis
        self._switch_host_module = None
        self.state_db = daemon_base.db_connect("STATE_DB")
        self.host_state_table = swsscommon.Table(self.state_db, HOST_STATE_TABLE)
        self.chassis_module_info_table = swsscommon.Table(self.state_db, CHASSIS_MODULE_INFO_TABLE)

    def _get_switch_host_module(self):
        """Return the Switch-Host Module object from the chassis module list."""
        if self._switch_host_module is not None:
            return self._switch_host_module
        try:
            modules = self.chassis.get_all_modules()
            for module in modules:
                module_type = try_get(module.get_type, default="")
                if module_type == "SWITCH-HOST":
                    self._switch_host_module = module
                    return self._switch_host_module
            if modules and len(modules) >= 2:
                self._switch_host_module = modules[1]
                return self._switch_host_module
        except Exception as e:
            self.log_error("Failed to retrieve Switch-Host module: {}".format(repr(e)))
        return None

    def get_oper_status(self):
        """Return the current operational status of Switch-Host (ONLINE/OFFLINE)."""
        # device_status: ONLINE | OFFLINE
        module = self._get_switch_host_module()
        if module is None:
            return NOT_AVAILABLE
        raw = try_get(module.get_oper_status, default=NOT_AVAILABLE)
        # Normalise to uppercase to match HOST_STATE DB schema (ONLINE / OFFLINE)
        return str(raw).upper() if raw != NOT_AVAILABLE else raw

    def _verify_oper_status(self, expected_status, timeout_secs, context):
        """
        Poll get_oper_status() until it matches expected_status or timeout_secs elapses.
        Returns True when confirmed, False on timeout.
        """
        deadline = time.time() + timeout_secs
        while time.time() < deadline:
            if self.get_oper_status() == expected_status:
                self.log_info("{}: oper_status confirmed {}".format(context, expected_status))
                return True
            time.sleep(POWER_VERIFY_POLL_INTERVAL_SECS)
        self.log_error("{}: oper_status did not reach {} within {}s (current: {})".format(
            context, expected_status, timeout_secs, self.get_oper_status()))
        return False

    def _apply_admin_state(self, admin_up, transitional_power_state, final_power_state, expected_oper, op_name):
        """
        Common implementation for power_on and power_off.
        Snapshots prior STATE_DB values, writes the transitional power state,
        issues set_admin_state, verifies the result, then writes the final power state.
        device_status is always written from module->get_oper_status() (ONLINE|OFFLINE).
        Rolls back to the prior STATE_DB snapshot on exception.
        """
        module = self._get_switch_host_module()
        if module is None:
            self.log_error("Cannot {} Switch-Host: module not found".format(op_name))
            return False
        prior_power_state = self.get_db_power_state()
        prior_status = self.get_db_device_status()
        try:
            # Write transitional power state (e.g. POWERING_ON/OFF) before platform call
            self._update_host_state(transitional_power_state)
            module.set_admin_state(admin_up)
            self.log_notice("Switch-Host {} issued; verifying oper_status...".format(op_name))
            verified = self._verify_oper_status(expected_oper, POWER_VERIFY_TIMEOUT_SECS, op_name)
            if not verified:
                self.log_error("Switch-Host {}: oper_status did not confirm {}".format(
                    op_name, expected_oper))
            # Write final stable power state (e.g. POWER_ON/OFF); device_status from live oper_status
            self._update_host_state(final_power_state)
            return verified
        except Exception as e:
            self.log_error("Failed to {} Switch-Host: {}".format(op_name, repr(e)))
            self._update_host_state(prior_power_state, prior_status)
            return False

    def power_on(self):
        """Power ON the Switch-Host via module->set_admin_state(True).

        device_power_state: POWERING_ON (transitional) -> POWER_ON (final)
        device_status:      ONLINE | OFFLINE from module->get_oper_status()
        """
        return self._apply_admin_state(
            True, SWITCH_HOST_POWERING_ON, POWER_STATE_ON, SWITCH_HOST_ONLINE, "power_on")

    def power_off(self):
        """Power OFF the Switch-Host via module->set_admin_state(False).

        device_power_state: POWERING_OFF (transitional) -> POWER_OFF (final)
        device_status:      ONLINE | OFFLINE from module->get_oper_status()
        """
        return self._apply_admin_state(
            False, SWITCH_HOST_POWERING_OFF, POWER_STATE_OFF, SWITCH_HOST_OFFLINE, "power_off")

    def power_cycle(self):
        """Power cycle the Switch-Host via module->do_power_cycle().

        device_power_state: POWER_CYCLING (transitional) -> POWER_CYCLE (final)
        device_status:      ONLINE | OFFLINE from module->get_oper_status()
        """
        module = self._get_switch_host_module()
        if module is None:
            self.log_error("Cannot power cycle Switch-Host: module not found")
            return False
        prior_power_state = self.get_db_power_state()
        prior_status = self.get_db_device_status()
        try:
            # Write transitional power state (POWER_CYCLING) before platform call
            self._update_host_state(SWITCH_HOST_POWER_CYCLING)
            try_get(module.do_power_cycle, default=False)
            self.log_notice("Switch-Host power cycle issued; verifying oper_status...")
            # Use 2x timeout: host must go offline then come back online
            verified = self._verify_oper_status(
                SWITCH_HOST_ONLINE, POWER_VERIFY_TIMEOUT_SECS * 2, "power_cycle")
            if not verified:
                self.log_error("Switch-Host power cycle: oper_status did not confirm ONLINE")
            # Write final stable power state; device_status from live oper_status
            self._update_host_state(POWER_STATE_CYCLE)
            return verified
        except Exception as e:
            self.log_error("Failed to power cycle Switch-Host: {}".format(repr(e)))
            self._update_host_state(prior_power_state, prior_status)
            return False

    def _update_host_state(self, power_state, device_status=None):
        """Write device_power_state and device_status to HOST_STATE STATE_DB.

        power_state   : device_power_state field value.
                        Transitional: POWERING_ON | POWERING_OFF | POWER_CYCLING
                        Final/stable: POWER_ON | POWER_OFF | POWER_CYCLE | GRACEFUL_SHUT
        device_status : device_status field value — always ONLINE | OFFLINE.
                        When None, fetched live from module->get_oper_status().
        """
        if device_status is None:
            device_status = self.get_oper_status()
        fvs = swsscommon.FieldValuePairs([
            (FIELD_DEVICE_POWER_STATE, power_state),
            (FIELD_DEVICE_STATUS, str(device_status)),
            (FIELD_LAST_CHANGE_TIMESTAMP, get_current_timestamp()),
        ])
        self.host_state_table.set(HOST_STATE_KEY, fvs)
        self._update_chassis_module_oper_status(device_status)

    def get_db_device_status(self):
        """Read device_status from HOST_STATE STATE_DB (reflects transitional states)."""
        result = self.host_state_table.get(HOST_STATE_KEY)
        if result and result[0]:
            return fvs_to_dict(result[1]).get(FIELD_DEVICE_STATUS, NOT_AVAILABLE)
        return NOT_AVAILABLE

    def get_db_power_state(self):
        """Read device_power_state from HOST_STATE STATE_DB."""
        result = self.host_state_table.get(HOST_STATE_KEY)
        if result and result[0]:
            return fvs_to_dict(result[1]).get(FIELD_DEVICE_POWER_STATE, NOT_AVAILABLE)
        return NOT_AVAILABLE

    def refresh_host_state(self):
        """Refresh HOST_STATE with current oper_status, preserving last power state.

        If no prior power state is recorded (N/A), infer it from oper_status:
        ONLINE -> POWER_ON, OFFLINE -> POWER_OFF.
        """
        result = self.host_state_table.get(HOST_STATE_KEY)
        cur_power_state = NOT_AVAILABLE
        if result and result[0]:
            cur_power_state = fvs_to_dict(result[1]).get(FIELD_DEVICE_POWER_STATE, NOT_AVAILABLE)
        oper_status = self.get_oper_status()
        if cur_power_state == NOT_AVAILABLE:
            cur_power_state = POWER_STATE_ON if str(oper_status).upper() == SWITCH_HOST_ONLINE else POWER_STATE_OFF
        self._update_host_state(cur_power_state, oper_status)

    def initialize_chassis_module_info(self, admin_status):
        """Populate CHASSIS_MODULE_TABLE|SWITCH-HOST in STATE_DB at daemon startup.

        Reads module identity fields from the platform and writes them alongside
        the current admin_status and oper_status.  Called once from
        BmcctldDaemon.__init__ after policy_reader is available.
        """
        module = self._get_switch_host_module()
        if module is None:
            self.log_error("Cannot initialize CHASSIS_MODULE_INFO: Switch-Host module not found")
            return
        name = SWITCH_HOST_MODULE_KEY
        desc = try_get(module.get_description, default=NOT_AVAILABLE)
        serial = try_get(module.get_serial, default=NOT_AVAILABLE)
        oper_status = self.get_oper_status()
        fvs = swsscommon.FieldValuePairs([
            (CHASSIS_MODULE_INFO_NAME_FIELD, name),
            (CHASSIS_MODULE_INFO_DESC_FIELD, desc),
            (CHASSIS_MODULE_INFO_SERIAL_FIELD, serial),
            (CHASSIS_MODULE_INFO_OPERSTATUS_FIELD, oper_status),
            (CHASSIS_MODULE_INFO_ADMIN_STATUS_FIELD, admin_status),
        ])
        self.chassis_module_info_table.set(SWITCH_HOST_MODULE_KEY, fvs)
        self.log_info(
            "CHASSIS_MODULE_INFO initialized for SWITCH-HOST: "
            "name={} serial={} admin_status={} oper_status={}".format(
                name, serial, admin_status, oper_status))

    def _update_chassis_module_oper_status(self, oper_status):
        """Update oper_status in CHASSIS_MODULE_TABLE|SWITCH-HOST to mirror HOST_STATE."""
        fvs = swsscommon.FieldValuePairs([
            (CHASSIS_MODULE_INFO_OPERSTATUS_FIELD, str(oper_status)),
        ])
        self.chassis_module_info_table.set(SWITCH_HOST_MODULE_KEY, fvs)

    def update_chassis_module_admin_status(self, admin_status):
        """Update admin_status in CHASSIS_MODULE_TABLE|SWITCH-HOST when config changes."""
        fvs = swsscommon.FieldValuePairs([
            (CHASSIS_MODULE_INFO_ADMIN_STATUS_FIELD, admin_status),
        ])
        self.chassis_module_info_table.set(SWITCH_HOST_MODULE_KEY, fvs)


# ============================================================
# PolicyReader
# ============================================================

class PolicyReader(EventLogger):
    """Reads bmcctld timing and leak policy configuration from CONFIG_DB."""

    def __init__(self):
        super(PolicyReader, self).__init__(SYSLOG_IDENTIFIER, DEFAULT_LOG_FILE)
        self.config_db = daemon_base.db_connect("CONFIG_DB")

    def _get_chassis_module_entry(self):
        """Return the CHASSIS_MODULE|SWITCH-HOST entry as a dict (empty dict if missing)."""
        tbl = swsscommon.Table(self.config_db, CHASSIS_MODULE_TABLE)
        result = tbl.get(SWITCH_HOST_MODULE_KEY)
        if result and result[0]:
            return fvs_to_dict(result[1])
        return {}

    def get_switch_host_admin_status(self):
        """Return admin_status for SWITCH-HOST from CHASSIS_MODULE|SWITCH-HOST (default: down)."""
        return self._get_chassis_module_entry().get(FIELD_ADMIN_STATUS, ADMIN_DOWN)

    def get_power_on_delay(self):
        """Return power_on_delay in seconds from CHASSIS_MODULE|SWITCH-HOST (default: 0)."""
        raw = self._get_chassis_module_entry().get(FIELD_POWER_ON_DELAY)
        if raw is not None:
            try:
                return int(raw)
            except (ValueError, TypeError):
                pass
        return DEFAULT_POWER_ON_DELAY_SECS

    def get_graceful_shutdown_timeout(self):
        """Return graceful_shutdown_timeout in seconds from CHASSIS_MODULE|SWITCH-HOST (default: 120)."""
        raw = self._get_chassis_module_entry().get(FIELD_GRACEFUL_SHUTDOWN_TIMEOUT)
        if raw is not None:
            try:
                return int(raw)
            except (ValueError, TypeError):
                pass
        return DEFAULT_SHUTDOWN_DELAY_SECS

    def get_leak_control_policy(self):
        """Return LEAK_CONTROL_POLICY as a dict with action defaults filled in."""
        policy = {
            "system_leak_policy": DEFAULT_SYSTEM_LEAK_POLICY,
            "system_critical_leak_action": DEFAULT_SYSTEM_CRITICAL_LEAK_ACTION,
            "system_minor_leak_action": DEFAULT_SYSTEM_MINOR_LEAK_ACTION,
            "rack_mgr_leak_policy": DEFAULT_RACK_MGR_LEAK_POLICY,
            "rack_mgr_critical_alert_action": DEFAULT_RACK_MGR_CRITICAL_ALERT_ACTION,
            "rack_mgr_minor_alert_action": DEFAULT_RACK_MGR_MINOR_ALERT_ACTION,
        }
        tbl = swsscommon.Table(self.config_db, LEAK_CONTROL_POLICY_TABLE)
        # LEAK_CONTROL_POLICY is a single-row table; CLI writes key "policy", legacy variants also tried
        for key in ("policy", LEAK_CONTROL_POLICY_TABLE, ""):
            result = tbl.get(key)
            if result and result[0]:
                policy.update({k: v for k, v in fvs_to_dict(result[1]).items() if k in policy})
                break
        return policy


# ============================================================
# CriticalEventChecker
# ============================================================

class CriticalEventChecker(EventLogger):
    """Checks current system and Rack Manager leak/alert status from STATE_DB."""

    # Alert keys in RACK_MANAGER_ALERT table
    ALERT_KEYS = [
        "Inlet_liquid_temperature",
        "Inlet_liquid_flow_rate",
        "Inlet_liquid_pressure",
        "Rack_level_leak",
    ]

    def __init__(self, policy_reader):
        super(CriticalEventChecker, self).__init__(SYSLOG_IDENTIFIER, CRITICAL_EVENT_LOG_FILE)
        self.state_db = daemon_base.db_connect("STATE_DB")
        self.policy_reader = policy_reader

    def has_critical_system_leak(self):
        """Return True if SYSTEM_LEAK_STATUS|system shows CRITICAL_SYSTEM_LEAK."""
        tbl = swsscommon.Table(self.state_db, SYSTEM_LEAK_STATUS_TABLE)
        result = tbl.get(SYSTEM_LEAK_STATUS_KEY)
        if result and result[0]:
            if fvs_to_dict(result[1]).get(FIELD_DEVICE_LEAK_STATUS) == SYSTEM_LEAK_CRITICAL:
                _event_logger.log_error("CRITICAL system leak detected in {}: {}={}".format(
                    SYSTEM_LEAK_STATUS_TABLE, FIELD_DEVICE_LEAK_STATUS, SYSTEM_LEAK_CRITICAL))
                return True
        return False

    def has_critical_rack_mgr_alert(self):
        """Return True if any RACK_MANAGER_ALERT entry has CRITICAL severity."""
        tbl = swsscommon.Table(self.state_db, RACK_MANAGER_ALERT_TABLE)
        for alert_key in self.ALERT_KEYS:
            result = tbl.get(alert_key)
            if result and result[0]:
                d = fvs_to_dict(result[1])
                # severity field for temperature/flow/pressure; leak field for rack-level leak
                severity = d.get(FIELD_SEVERITY) or d.get(FIELD_LEAK, ALERT_SEVERITY_NORMAL)
                if severity == ALERT_SEVERITY_CRITICAL:
                    _event_logger.log_error("CRITICAL Rack Manager alert: key={} severity={}".format(
                        alert_key, severity))
                    return True
        return False

    def has_any_critical_event(self):
        """Return True if any critical system or Rack Manager event is active and its policy is enabled.

        Skips system leak check if system_leak_policy == 'disabled'.
        Skips Rack Manager alert check if rack_mgr_leak_policy == 'disabled'.
        """
        policy = self.policy_reader.get_leak_control_policy()
        if policy.get("system_leak_policy") != "disabled" and self.has_critical_system_leak():
            return True
        if policy.get("rack_mgr_leak_policy") != "disabled" and self.has_critical_rack_mgr_alert():
            return True
        return False

    def get_system_leak_status(self):
        """Return device_leak_status string from SYSTEM_LEAK_STATUS table."""
        tbl = swsscommon.Table(self.state_db, SYSTEM_LEAK_STATUS_TABLE)
        result = tbl.get(SYSTEM_LEAK_STATUS_KEY)
        if result and result[0]:
            return fvs_to_dict(result[1]).get(FIELD_DEVICE_LEAK_STATUS, "")
        return ""


# ============================================================
# GracefulShutdownHandler
# ============================================================

class GracefulShutdownHandler(EventLogger):
    """
    Issues a GNOI soft shutdown to Switch-Host and waits graceful_shutdown_timeout
    seconds for it to go OFFLINE.  Call platform power_off after the graceful_shutdown_timeout
    irrespective of GNOI request succeeded or not.
    """

    def __init__(self, controller, policy_reader):
        super(GracefulShutdownHandler, self).__init__(SYSLOG_IDENTIFIER, CRITICAL_EVENT_LOG_FILE)
        self.controller = controller
        self.policy_reader = policy_reader

    def execute(self):
        """
        Perform graceful shutdown of Switch-Host.
        Sends gNOI System.Reboot(COLD) and waits for the host to go OFFLINE,
        then always issues power_off() to ensure power is removed.
        Returns True on success, False on failure.
        """
        graceful_shutdown_timeout = self.policy_reader.get_graceful_shutdown_timeout()
        self.log_notice("Initiating graceful shutdown of Switch-Host (timeout={}s)".format(graceful_shutdown_timeout))

        prior_power_state = self.controller.get_db_power_state()
        prior_status = self.controller.get_db_device_status()

        # Write transitional power state (GRACEFUL_SHUTTING_DOWN) before issuing shutdown
        self.controller._update_host_state(SWITCH_HOST_GRACEFUL_SHUTTING_DOWN)

        # graceful_shutdown_timeout == 0 means skip GNOI and force power-off immediately
        if graceful_shutdown_timeout == 0:
            self.log_notice("graceful_shutdown_timeout is 0: forcing immediate power OFF")
            return self.controller.power_off()

        try:
            gnoi_ok = self._issue_gnoi_shutdown()
        except Exception as e:
            self.log_error("Unexpected error during GNOI shutdown: {}".format(repr(e)))
            self.controller._update_host_state(prior_power_state, prior_status)
            return False

        if not gnoi_ok:
            self.log_warning("GNOI shutdown request failed; proceeding with power OFF")
        else:
            # Wait up to graceful_shutdown_timeout for Switch-Host to go OFFLINE gracefully
            self.log_info("Waiting up to {}s for Switch-Host to go OFFLINE...".format(graceful_shutdown_timeout))
            went_offline = self.controller._verify_oper_status(
                SWITCH_HOST_OFFLINE, graceful_shutdown_timeout, "graceful_shutdown")
            if went_offline:
                self.log_notice("Switch-Host went OFFLINE gracefully; issuing power OFF")
            else:
                self.log_warning("Graceful shutdown timed out after {}s; issuing power OFF".format(
                    graceful_shutdown_timeout))

        return self.controller.power_off()

    def _issue_gnoi_shutdown(self):
        # TODO: This approach of calling gnoi_client to be replaced by idea in this PR
        # https://github.com/sonic-net/sonic-host-services/pull/361
        """
        Send a GNOI System.Reboot (COLD/graceful) request to the Switch-Host.
        Returns True if the request was accepted, False otherwise.
        Reference: https://github.com/sonic-net/SONiC/blob/master/doc/mgmt/gnmi/gnoi_system_hld.md
        switch_host_addr = self._get_switch_host_addr()
        self.log_info("Sending GNOI shutdown to Switch-Host at {}".format(switch_host_addr))
        try:
            result = subprocess.run(
                [
                    "gnoi_client",
                    "-target", switch_host_addr,
                    "-rpc", "System.Reboot",
                    "-jsonin", '{"method": 1}',  # method 1 = COLD (graceful reboot/shutdown)
                ],
                timeout=GNOI_REQUEST_TIMEOUT_SECS,
                capture_output=True,
                text=True,
            )
            if result.returncode == 0:
                self.log_notice("GNOI shutdown request accepted by Switch-Host")
                return True
            self.log_warning("GNOI shutdown failed (rc={}): {}".format(result.returncode, result.stderr))
            return False
        except subprocess.TimeoutExpired:
            self.log_warning("GNOI shutdown request timed out after {}s".format(GNOI_REQUEST_TIMEOUT_SECS))
            return False
        except FileNotFoundError:
            self.log_warning("gnoi_client not found; cannot issue graceful shutdown")
            return False
        except Exception as e:
            self.log_warning("GNOI shutdown exception: {}".format(repr(e)))
            return False
        """
        return True

    def _get_switch_host_addr(self):
        """Read Switch-Host address from bmc.json; fall back to hardcoded default."""
        for path in BMC_JSON_PATHS:
            try:
                with open(path) as f:
                    data = json.load(f)
                    addr = data.get("bmc_if_addr")
                    if addr:
                        return addr
            except (FileNotFoundError, json.JSONDecodeError, OSError):
                continue
        return DEFAULT_SWITCH_HOST_ADDR


# ============================================================
# BmcEventHandler
# ============================================================

class BmcEventHandler(EventLogger):
    """
    Runs in a dedicated daemon thread.  Subscribes to RACK_MANAGER_COMMAND,
    CHASSIS_MODULE, RACK_MANAGER_ALERT, and SYSTEM_LEAK_STATUS tables.

    On each event it decides what action is needed and puts an ActionItem on
    action_queue.  All blocking power operations are executed by the main
    daemon thread — this class never blocks.
    """

    def __init__(self, action_queue, policy_reader, critical_event_checker, stop_event,
                 controller):
        super(BmcEventHandler, self).__init__(SYSLOG_IDENTIFIER, DEFAULT_LOG_FILE)
        self._event_log = _event_logger  # for critical leak / alert events only
        self.action_queue = action_queue
        self.policy_reader = policy_reader
        self.critical_event_checker = critical_event_checker
        self.stop_event = stop_event
        self.controller = controller

        self.state_db = daemon_base.db_connect("STATE_DB")
        self.config_db = daemon_base.db_connect("CONFIG_DB")

        # One SubscriberStateTable per watched table
        self.rack_mgr_cmd_sub = swsscommon.SubscriberStateTable(
            self.state_db, RACK_MANAGER_COMMAND_TABLE)
        self.chassis_module_sub = swsscommon.SubscriberStateTable(
            self.config_db, CHASSIS_MODULE_TABLE)
        self.rack_mgr_alert_sub = swsscommon.SubscriberStateTable(
            self.state_db, RACK_MANAGER_ALERT_TABLE)
        self.system_leak_sub = swsscommon.SubscriberStateTable(
            self.state_db, SYSTEM_LEAK_STATUS_TABLE)

        # Map fd -> (table, handler).
        # getFd() returns a stable integer regardless of how swsscommon re-wraps
        # the C++ Selectable* returned by sel.select().  The table reference is
        # kept here because sel.select() returns a raw Selectable that has
        # getFd() but no pop(); pop() must be called on the original
        # SubscriberStateTable object.
        self._subscribers = {
            self.rack_mgr_cmd_sub.getFd():   (self.rack_mgr_cmd_sub,   self._handle_rack_mgr_command),
            self.chassis_module_sub.getFd(): (self.chassis_module_sub, self._handle_chassis_module),
            self.rack_mgr_alert_sub.getFd(): (self.rack_mgr_alert_sub, self._handle_rack_mgr_alert),
            self.system_leak_sub.getFd():    (self.system_leak_sub,    self._handle_system_leak),
        }

        self.sel = swsscommon.Select()
        self.sel.addSelectable(self.rack_mgr_cmd_sub)
        self.sel.addSelectable(self.chassis_module_sub)
        self.sel.addSelectable(self.rack_mgr_alert_sub)
        self.sel.addSelectable(self.system_leak_sub)

    # ---- public ----

    def run_event_loop(self):
        """Block in select loop until stop_event is set."""
        self.log_info("Entering event subscription loop")
        while not self.stop_event.is_set():
            state, selectable = self.sel.select(SELECT_TIMEOUT_MSECS)
            if state == swsscommon.Select.TIMEOUT:
                continue
            if state != swsscommon.Select.OBJECT:
                self.log_warning("sel.select() returned unexpected state: {}".format(state))
                continue
            fd = selectable.getFd()
            entry = self._subscribers.get(fd)
            if entry is None:
                self.log_warning("sel.select() returned unknown fd={}".format(fd))
                continue
            table, handler = entry
            key, op, fvs = table.pop()
            if op != "SET":
                continue
            handler(key, fvs_to_dict(fvs))

    # ---- internal event handlers ----

    def _handle_rack_mgr_command(self, key, fvs):
        """Process a RACK_MANAGER_COMMAND entry (POWER_ON / POWER_OFF / POWER_CYCLE)."""
        command = fvs.get(FIELD_COMMAND, "")
        cmd_status = fvs.get(FIELD_STATUS, "")

        # Skip already-processed commands
        if cmd_status not in (CMD_STATUS_PENDING, ""):
            return

        self.log_notice("Rack Manager command: key={} command={}".format(key, command))
        self._set_cmd_status(key, CMD_STATUS_IN_PROGRESS)

        if command == CMD_POWER_ON:
            if self.critical_event_checker.has_any_critical_event():
                self.log_warning("POWER_ON blocked: active critical leak or alert")
                self._set_cmd_status(key, CMD_STATUS_FAILED, "CRITICAL_LEAK_PRESENT")
                return

        elif command not in (CMD_POWER_OFF, CMD_GRACEFUL_SHUT, CMD_POWER_CYCLE):
            self.log_warning("Unknown Rack Manager command: {}".format(command))
            self._set_cmd_status(key, CMD_STATUS_FAILED, "UNKNOWN_COMMAND")
            return

        action_map = {
            CMD_POWER_OFF:    ACTION_POWER_OFF,
            CMD_GRACEFUL_SHUT: ACTION_GRACEFUL_SHUTDOWN,
            CMD_POWER_ON:    ACTION_POWER_ON,
            CMD_POWER_CYCLE: ACTION_POWER_CYCLE,
        }

        def on_complete(success, cmd_key=key):
            self._set_cmd_status(cmd_key,
                                 CMD_STATUS_DONE if success else CMD_STATUS_FAILED,
                                 "SUCCESS" if success else "ERROR")

        self.action_queue.put(ActionItem(action_map[command],
                                         "RACK_MGR_CMD:{}".format(command),
                                         on_complete))

    def _handle_chassis_module(self, key, fvs):
        """Process CHASSIS_MODULE admin_status change (admin up/down from CLI)."""
        admin_status = fvs.get(FIELD_ADMIN_STATUS, "")
        self.log_notice("CHASSIS_MODULE change: key={} admin_status={}".format(key, admin_status))

        # Mirror admin_status to CHASSIS_MODULE_INFO_TABLE immediately on config change
        if admin_status:
            self.controller.update_chassis_module_admin_status(admin_status)

        if admin_status == ADMIN_DOWN:
            if self.controller.get_db_device_status() != SWITCH_HOST_ONLINE:
                self.log_info("admin_down: Switch-Host already OFFLINE; no action needed")
                return
            self.log_notice("CHASSIS_MODULE admin_down: initiating graceful shutdown of Switch-Host")
            self.action_queue.put(ActionItem(ACTION_GRACEFUL_SHUTDOWN, "CHASSIS_MODULE:ADMIN_DOWN"))

        elif admin_status == ADMIN_UP:
            if self.controller.get_db_device_status() == SWITCH_HOST_ONLINE:
                self.log_info("admin_up: Switch-Host already ONLINE; no action needed")
                return
            if self.critical_event_checker.has_any_critical_event():
                self.log_warning("admin_up: POWER_ON blocked by active critical leak or alert")
                return
            self.log_notice("CHASSIS_MODULE admin_up: powering ON Switch-Host")
            self.action_queue.put(ActionItem(ACTION_POWER_ON, "CHASSIS_MODULE:ADMIN_UP"))

    def _handle_system_leak(self, key, fvs):
        """Process SYSTEM_LEAK_STATUS change from thermalctld."""
        if key != SYSTEM_LEAK_STATUS_KEY:
            return

        leak_status = fvs.get(FIELD_DEVICE_LEAK_STATUS, "")
        policy = self.policy_reader.get_leak_control_policy()

        if policy.get("system_leak_policy") == "disabled":
            self.log_info("system_leak_policy disabled; skipping leak event key={}".format(key))
            return

        if leak_status == SYSTEM_LEAK_CRITICAL:
            action = policy.get("system_critical_leak_action", DEFAULT_SYSTEM_CRITICAL_LEAK_ACTION)
            self._event_log.log_notice("CRITICAL SYSTEM LEAK detected (status={}); "
                                       "action={}".format(leak_status, action))
            self._dispatch_action(action, "CRITICAL_SYSTEM_LEAK")

        elif leak_status == SYSTEM_LEAK_MINOR:
            action = policy.get("system_minor_leak_action", DEFAULT_SYSTEM_MINOR_LEAK_ACTION)
            self._dispatch_action(action, "MINOR_SYSTEM_LEAK")

        else:
            self.log_notice("System leak cleared (status={}); no automatic power-on".format(leak_status))

    def _log_host_thermal_sensors_above_threshold(self):
        """Read TEMPERATURE_INFO from STATE_DB and log any sensor in warning state."""
        try:
            tbl = swsscommon.Table(self.state_db, "TEMPERATURE_INFO")
            keys = tbl.getKeys()
            above = []
            for sensor_name in keys:
                result = tbl.get(sensor_name)
                if not result or not result[0]:
                    continue
                d = fvs_to_dict(result[1])
                if str(d.get("warning", "False")).lower() == "true":
                    above.append(
                        "  {} temp={} high_th={} crit_high_th={}".format(
                            sensor_name,
                            d.get("temperature", NOT_AVAILABLE),
                            d.get("high_threshold", NOT_AVAILABLE),
                            d.get("critical_high_threshold", NOT_AVAILABLE),
                        )
                    )
            if above:
                self._event_log.log_notice(
                    "Switch-Host thermal sensors above threshold ({} sensor(s)):\n{}".format(
                        len(above), "\n".join(above)))
            else:
                self._event_log.log_notice(
                    "Switch-Host: no thermal sensors above threshold at time of alert")
        except Exception as e:
            self.log_warning("Failed to read Switch-Host thermal sensors: {}".format(repr(e)))

    def _handle_rack_mgr_alert(self, key, fvs):
        """Process RACK_MANAGER_ALERT change from Rack Manager (via redfish docker)."""
        severity = fvs.get(FIELD_SEVERITY) or fvs.get(FIELD_LEAK, ALERT_SEVERITY_NORMAL)
        policy = self.policy_reader.get_leak_control_policy()

        if policy.get("rack_mgr_leak_policy") == "disabled":
            self.log_info("rack_mgr_leak_policy disabled; skipping alert key={}".format(key))
            return

        if severity == ALERT_SEVERITY_CRITICAL:
            action = policy.get("rack_mgr_critical_alert_action", DEFAULT_RACK_MGR_CRITICAL_ALERT_ACTION)
            self._event_log.log_notice("CRITICAL RACK MGR ALERT (severity={} key={}); "
                                       "action={}".format(severity, key, action))
            self._log_host_thermal_sensors_above_threshold()
            self._dispatch_action(action, "RACK_MGR_CRITICAL_EVENT key={}".format(key))

        elif severity in (ALERT_SEVERITY_MINOR, ALERT_SEVERITY_MAJOR):
            action = policy.get("rack_mgr_minor_alert_action", DEFAULT_RACK_MGR_MINOR_ALERT_ACTION)
            self._dispatch_action(action, "RACK_MGR_MINOR_EVENT key={}".format(key))

        else:
            self.log_info("Rack Manager alert cleared for key={}; no action taken".format(key))

    # ---- dispatch helpers ----

    def _dispatch_action(self, action, event_desc):
        """
        Enqueue a power action for the main thread.
        syslog_only is handled inline; all other actions go on action_queue.
        """
        self.log_notice("Event '{}' -> action '{}'".format(event_desc, action))
        if action == ACTION_SYSLOG_ONLY:
            return
        if action in (ACTION_GRACEFUL_SHUTDOWN, ACTION_POWER_OFF, ACTION_POWER_ON):
            self.action_queue.put(ActionItem(action, event_desc))
        else:
            self.log_warning("Unknown action '{}' for event '{}'; defaulting to syslog_only".format(
                action, event_desc))

    def _set_cmd_status(self, cmd_id, status, result="SUCCESS"):
        """Update RACK_MANAGER_COMMAND entry with execution status."""
        tbl = swsscommon.Table(self.state_db, RACK_MANAGER_COMMAND_TABLE)
        fvs = swsscommon.FieldValuePairs([
            (FIELD_STATUS, status),
            (FIELD_RESULT, result),
            (FIELD_LAST_CHANGE_TIMESTAMP, get_current_timestamp()),
        ])
        tbl.set(cmd_id, fvs)


# ============================================================
# BmcctldDaemon
# ============================================================

class BmcctldDaemon(daemon_base.DaemonBase):
    """
    Main daemon class.  Performs the initial Switch-Host power-on sequence
    and then enters a blocking DB event loop.
    """

    FATAL_SIGNALS = [signal.SIGINT, signal.SIGTERM]
    NONFATAL_SIGNALS = [signal.SIGHUP]

    def __init__(self, log_identifier):
        super(BmcctldDaemon, self).__init__(log_identifier)
        self.set_min_log_priority_info()

        # Global event logger available to the daemon for critical log entries
        self._event_log = _event_logger

        self.stop_event = threading.Event()

        # Load platform chassis (Switch-Host + BMC modules exposed here)
        try:
            import sonic_platform.platform
            self.chassis = sonic_platform.platform.Platform().get_chassis()
        except Exception as e:
            self.log_error("Failed to load platform chassis: {}".format(repr(e)))
            sys.exit(CHASSIS_LOAD_ERROR)

        self.controller = SwitchHostController(self.chassis)
        self.policy_reader = PolicyReader()
        self.critical_event_checker = CriticalEventChecker(self.policy_reader)
        self.graceful_shutdown = GracefulShutdownHandler(self.controller, self.policy_reader)
        self.action_queue = queue.Queue()
        self.event_handler = BmcEventHandler(
            self.action_queue,
            self.policy_reader,
            self.critical_event_checker,
            self.stop_event,
            self.controller,
        )

        # Populate CHASSIS_MODULE_INFO_TABLE at startup with module identity and status
        admin_status = self.policy_reader.get_switch_host_admin_status()
        self.controller.initialize_chassis_module_info(admin_status)

        for signum in self.FATAL_SIGNALS + self.NONFATAL_SIGNALS:
            try:
                signal.signal(signum, self.signal_handler)
            except Exception as e:
                self.log_error("Cannot register signal handler for {}: {}".format(signum, e))

    # Override signal handler from DaemonBase
    def signal_handler(self, sig, frame):
        global exit_code
        if sig in self.FATAL_SIGNALS:
            exit_code = 128 + sig
            self.log_info("Caught signal '{}' ({}); exiting...".format(
                SIGNALS_TO_NAMES_DICT.get(sig, sig), exit_code))
            self.stop_event.set()
        elif sig in self.NONFATAL_SIGNALS:
            self.log_info("Caught signal '{}'; ignoring".format(SIGNALS_TO_NAMES_DICT.get(sig, sig)))
        else:
            self.log_warning("Caught unhandled signal '{}'; ignoring".format(
                SIGNALS_TO_NAMES_DICT.get(sig, sig)))

    def _rack_mgr_power_cmd_executed(self):
        """
        Return True if any RACK_MANAGER_COMMAND entry for POWER_ON or POWER_OFF
        has status IN_PROGRESS or DONE — indicating the Rack Manager issued an
        explicit power directive during the boot delay.
        """
        tbl = swsscommon.Table(self.event_handler.state_db, RACK_MANAGER_COMMAND_TABLE)
        for key in tbl.getKeys():
            result = tbl.get(key)
            if not (result and result[0]):
                continue
            entry = fvs_to_dict(result[1])
            command = entry.get(FIELD_COMMAND, "")
            status = entry.get(FIELD_STATUS, "")
            if command in (CMD_POWER_ON, CMD_POWER_OFF, CMD_GRACEFUL_SHUT) and \
               status in (CMD_STATUS_IN_PROGRESS, CMD_STATUS_DONE):
                return True
        return False

    def _initial_power_on_sequence(self):
        """
        BMC startup flow
          1. Check CHASSIS_MODULE admin_status for SWITCH-HOST. If 'down' (the default),
             Switch-Host stays powered off — exit immediately. The operator must run
             'config chassis modules startup SWITCH-HOST' to bring it up.
          2. Sleep SWITCH_HOST_POWER_ON_DELAY seconds to allow Rack Manager to come
             up and verify liquid flow (liquid-cooled) or simply stabilise (air-cooled).
             While sleeping, keep draining the action_queue so Rack Manager commands
             (e.g. POWER_OFF) arriving during the delay are acted on immediately.
          3. After the delay, check if Rack Manager issued an explicit POWER_ON,
             POWER_OFF, or GRACEFUL_SHUT command (CMD_STATUS_IN_PROGRESS or DONE in
             RACK_MANAGER_COMMAND table). If so, skip automatic power-on.
          4. Check for CRITICAL leaks/alerts.
          5. If none found and Switch-Host is OFFLINE, power it ON.
          6. Update HOST_STATE.
        """
        admin_status = self.policy_reader.get_switch_host_admin_status()
        if admin_status != ADMIN_UP:
            self._event_log.log_notice("STARTUP: SWITCH-HOST admin_status='{}' (default=down); "
                                       "Switch-Host will remain powered off. "
                                       "Run 'config chassis modules startup SWITCH-HOST' to power on.".format(admin_status))
            return

        # TODO : Optimize by adding this delay only to a case when there is a cold boot
        boot_delay = self.policy_reader.get_power_on_delay()
        self.log_notice("Waiting {}s before initial Switch-Host power-on check "
                                   "(SWITCH_HOST_POWER_ON_DELAY)".format(boot_delay))

        # Drain the action queue while we wait so Rack Manager / admin commands
        # received during the boot delay are processed in real time.
        deadline = time.time() + boot_delay
        while time.time() < deadline:
            if self.stop_event.is_set():
                return
            try:
                item = self.action_queue.get(timeout=1.0)
                self._execute_action_item(item)
            except queue.Empty:
                continue

        # After the boot delay, check whether a Rack Manager POWER_ON or POWER_OFF
        # command was executed. We detect this by scanning the RACK_MANAGER_COMMAND
        # table for any entry whose command is POWER_ON/POWER_OFF and whose status
        # is IN_PROGRESS or DONE (set by the event handler and on_complete callback).
        if self._rack_mgr_power_cmd_executed():
            self.log_notice("STARTUP: Rack Manager POWER_ON/POWER_OFF command executed "
                                       "during boot delay; skipping automatic power-on")
            return

        if self.critical_event_checker.has_any_critical_event():
            self._event_log.log_warning("STARTUP: Critical leak or Rack Manager alert detected; NOT powering on Switch-Host")
            return

        oper_status = self.controller.get_oper_status()
        self.log_info("STARTUP: Switch-Host oper_status={}".format(oper_status))

        if str(oper_status).upper() != SWITCH_HOST_ONLINE:
            self._event_log.log_notice("STARTUP: Switch-Host OFFLINE — issuing power_on")
            self.controller.power_on()
        else:
            self._event_log.log_notice("STARTUP: Switch-Host already ONLINE; refreshing HOST_STATE")
            self.controller.refresh_host_state()

    def _execute_action_item(self, item):
        """
        Execute a single ActionItem on the main thread.
        Calls item.on_complete(success) when finished if a callback was provided.
        """
        self._event_log.log_notice("Executing action '{}' (event: '{}')".format(item.action, item.event_desc))

        current_status = self.controller.get_oper_status()
        db_power_state = self.controller.get_db_power_state()
        if item.action in (ACTION_GRACEFUL_SHUTDOWN, ACTION_POWER_OFF):
            if current_status == SWITCH_HOST_OFFLINE or db_power_state in (
                    SWITCH_HOST_POWERING_OFF, SWITCH_HOST_GRACEFUL_SHUTTING_DOWN):
                self._event_log.log_notice(
                    "ACTION SKIPPED: '{}' trigger='{}' — "
                    "host already OFFLINE or shutting down (db_power_state={})".format(
                        item.action, item.event_desc, db_power_state))
                if item.on_complete:
                    item.on_complete(True)
                return
        elif item.action == ACTION_POWER_ON:
            if current_status == SWITCH_HOST_ONLINE or db_power_state == SWITCH_HOST_POWERING_ON:
                self._event_log.log_notice(
                    "ACTION SKIPPED: '{}' trigger='{}' — "
                    "host already ONLINE or POWERING_ON (db_power_state={})".format(
                        item.action, item.event_desc, db_power_state))
                if item.on_complete:
                    item.on_complete(True)
                return

        success = False
        if item.action == ACTION_GRACEFUL_SHUTDOWN:
            success = self.graceful_shutdown.execute()
        elif item.action == ACTION_POWER_OFF:
            success = self.controller.power_off()
        elif item.action == ACTION_POWER_ON:
            success = self.controller.power_on()
        elif item.action == ACTION_POWER_CYCLE:
            success = self.controller.power_cycle()
        else:
            self.log_warning("Unknown action '{}' in queue; skipping".format(item.action))
            return
        self._event_log.log_notice("ACTION DONE: action='{}' trigger='{}' "
                                   "success={}".format(item.action, item.event_desc, success))
        if item.on_complete:
            item.on_complete(success)

    def _run_action_loop(self):
        """
        Main thread action processor.  Dequeues and executes ActionItems
        sequentially until stop_event is set.  Actions are serialised naturally
        by this single consumer — no extra locking needed.
        """
        self.log_info("Entering action processing loop")
        while not self.stop_event.is_set():
            try:
                item = self.action_queue.get(timeout=1.0)
            except queue.Empty:
                continue
            self._execute_action_item(item)

    def run(self):
        """
        Called once by the main loop.  Startup flow:

          1. If Switch-Host is already ONLINE (daemon restart): skip boot
             sequence, refresh STATE_DB, enter action loop immediately.
          2. Non-liquid-cooled: power on immediately, no boot delay or
             leak/alert checks, then enter action loop.
          3. Liquid-cooled (normal boot): run _initial_power_on_sequence
             (boot delay + leak check), then enter action loop.

        The BmcEventHandler thread is always started first so CLI admin
        commands are captured regardless of the startup path.

        Returns False to terminate the outer while-loop.
        """
        self._event_log.log_notice("bmcctld starting up")

        # Always start the event thread — it handles CLI admin up/down commands
        # (CHASSIS_MODULE admin_status) regardless of cooling type.
        event_thread = threading.Thread(
            target=self.event_handler.run_event_loop,
            daemon=True,
            name="bmcctld-events",
        )
        event_thread.start()

        # If Switch-Host is already ONLINE (daemon restart), skip the boot
        # sequence entirely and go straight to the action loop.
        if self.controller.get_oper_status() == SWITCH_HOST_ONLINE:
            self._event_log.log_notice("STARTUP: Switch-Host already ONLINE (daemon restart); "
                                       "skipping boot sequence")
            self.controller.refresh_host_state()
        elif not is_liquid_cooled():
            self._event_log.log_notice("STARTUP: non-liquid-cooled system — "
                                       "immediate power_on, no additional checks")
            self.controller.power_on()
        else:
            # Liquid-cooled: wait for Rack Manager to verify liquid flow, check for
            # leaks/alerts, then power on if safe.
            self._initial_power_on_sequence()
            if self.stop_event.is_set():
                event_thread.join(timeout=5)
                return False

        self._run_action_loop()
        event_thread.join(timeout=5)
        return False

    def deinit(self):
        self.log_notice("bmcctld shutting down")
        self.stop_event.set()


# ============================================================
# Main
# ============================================================

def main():
    daemon = BmcctldDaemon(SYSLOG_IDENTIFIER)
    daemon.log_info("Starting up...")

    while daemon.run():
        pass

    daemon.log_info("Shutting down with exit code {}...".format(exit_code))
    daemon.deinit()
    return exit_code


if __name__ == "__main__":
    sys.exit(main())
