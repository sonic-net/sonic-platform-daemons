#!/usr/bin/env python3

"""
    bmcctld — BMC Controller Daemon for SONiC
    ==========================================
    Runs in the SONiC BMC pmon container and manages the Switch-Host power
    lifecycle in response to system events, Rack Manager commands, and
    operator requests.

    Event sources:
      - System leak detection from thermalctld  (STATE_DB: SYSTEM_LEAK_STATUS)
      - Rack Manager alerts / commands          (STATE_DB: RACK_MANAGER_ALERT /
                                                           RACK_MANAGER_COMMAND)
      - Operator admin up/down                  (STATE_DB: CHASSIS_MODULE)

    Classes:
      EventLogger            Dual-output logger: syslog + /host/bmc/event.log.
                             All daemon classes inherit from this.
      ActionItem             Data class carrying a pending power action from the
                             event thread to the main thread via action_queue.
      SwitchHostController   Issues power_on/off/cycle via the platform API and
                             keeps STATE_DB:HOST_STATE current.  Writes
                             transitional states (POWERING_ON/OFF/CYCLING)
                             before each call; rolls back on exception.
      PolicyReader           Reads admin_status, power_on_delay, and
                             graceful_shutdown_timeout from CHASSIS_MODULE|SWITCH-HOST in CONFIG_DB.
      CriticalEventChecker   Checks STATE_DB for active critical system leaks or
                             Rack Manager alerts; gates power-on decisions.
      GracefulShutdownHandler  Sends gNOI System.Reboot(COLD), waits for OFFLINE,
                             then always issues power_off() to ensure power is
                             removed.  Falls back to immediate power_off if gNOI
                             fails or graceful_shutdown_timeout is 0.
      BmcEventHandler        Runs on the "bmcctld-events" thread.  Subscribes to
                             STATE_DB and enqueues ActionItems for the main thread.
      BmcctldDaemon          Main daemon.  Starts the event thread, runs the
                             boot-delay sequence (liquid-cooled) or immediate
                             power-on (non-liquid-cooled), then processes the
                             action queue with idempotency enforcement.
"""

try:
    import json
    import logging
    import os
    import queue
    import signal
    import sys
    import threading
    import time
    from datetime import datetime

    from sonic_py_common import daemon_base, logger

    try:
        from sonic_py_common import is_liquid_cooled
    except ImportError:
        # Fall back to liquid-cooled (safe default — full monitoring enabled)
        def is_liquid_cooled():
            return True

    if os.getenv("BMCCTLD_UNIT_TESTING") == "1":
        from tests import mock_swsscommon as swsscommon
    else:
        from swsscommon import swsscommon
except ImportError as e:
    raise ImportError(str(e) + " - required module not found")


DEFAULT_LOG_FILE = "/var/log/syslog"
CRITICAL_EVENT_LOG_FILE = "/host/bmc/event.log"


# This class could be moved to sonic-py-common, the log file name can be passed as input.
class EventLogger(logger.Logger):
    """
    Extends sonic_py_common Logger to tee every log call to a local file in
    addition to syslog.  All bmcctld classes inherit from this so that
    power-state transitions and event handling are recorded in a dedicated
    log file that survives syslog rotation and is easy to grep offline.
    """

    def __init__(self, syslog_identifier, log_file=DEFAULT_LOG_FILE):
        super(EventLogger, self).__init__(syslog_identifier)
        # Derive a unique Python logger name per log file so instances writing
        # to different files do not share handlers.
        py_name = "{}.{}".format(syslog_identifier,
                                 os.path.basename(log_file).replace(".", "_"))
        self._file_logger = logging.getLogger(py_name)
        if not self._file_logger.handlers and os.getenv("BMCCTLD_UNIT_TESTING") != "1":
            handler = logging.FileHandler(log_file)
            handler.setFormatter(logging.Formatter(
                "%(asctime)s %(name)s[%(process)d] %(levelname)s: %(message)s",
                datefmt="%Y-%m-%dT%H:%M:%S",
            ))
            self._file_logger.addHandler(handler)
            self._file_logger.setLevel(logging.DEBUG)

    def log_debug(self, msg, also_print_to_console=False):
        super(EventLogger, self).log_debug(msg, also_print_to_console)
        self._file_logger.debug(msg)

    def log_info(self, msg, also_print_to_console=False):
        super(EventLogger, self).log_info(msg, also_print_to_console)
        self._file_logger.info(msg)

    def log_notice(self, msg, also_print_to_console=False):
        super(EventLogger, self).log_notice(msg, also_print_to_console)
        self._file_logger.info("NOTICE: " + msg)

    def log_warning(self, msg, also_print_to_console=False):
        super(EventLogger, self).log_warning(msg, also_print_to_console)
        self._file_logger.warning(msg)

    def log_error(self, msg, also_print_to_console=False):
        super(EventLogger, self).log_error(msg, also_print_to_console)
        self._file_logger.error(msg)


class ActionItem:
    """
    Carries a power action from the BmcEventHandler thread to the
    BmcctldDaemon main thread action loop.

    on_complete(success: bool) is called by the main thread after the
    action finishes — used by Rack Manager command handlers to write the
    final CMD_STATUS_DONE / CMD_STATUS_FAILED back to STATE_DB.
    """
    def __init__(self, action, event_desc, on_complete=None):
        self.action = action
        self.event_desc = event_desc
        self.on_complete = on_complete


